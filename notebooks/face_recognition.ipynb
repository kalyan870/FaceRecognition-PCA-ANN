{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Face Recognition using PCA (Eigenfaces) + ANN\n",
    "\n",
    "This notebook demonstrates a complete face recognition pipeline:\n",
    "1. Load and preprocess face images\n",
    "2. Apply PCA for dimensionality reduction (Eigenfaces)\n",
    "3. Train an Artificial Neural Network (ANN) classifier\n",
    "4. Evaluate accuracy for different k values\n",
    "5. Test on unknown faces and detect imposters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "sys.path.insert(0, os.path.abspath('..'))\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import cv2\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "\n",
    "from src.preprocess import load_dataset\n",
    "from src.pca import PCA\n",
    "from src.eigenfaces import save_eigenfaces, save_explained_variance\n",
    "from src.ann_model import ANNModel\n",
    "from src.train import train_pipeline\n",
    "from src.test import test_single_image, test_folder, test_imposters\n",
    "from src.utils import plot_accuracy_vs_k\n",
    "\n",
    "%matplotlib inline\n",
    "print(\"All imports successful!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Phase 1: Load Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, y_train, y_test, label_map, train_files, test_files = load_dataset(\n",
    "    '../dataset/train', '../dataset/test'\n",
    ")\n",
    "print(f\"Label map: {label_map}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Phase 2-3: PCA + ANN Training\n",
    "\n",
    "We test multiple k values (5, 10, 20, 30, 40) to find the optimal number of eigenfaces."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "k_values = [5, 10, 20, 30, 40]\n",
    "best_pca, best_ann, label_map, k_vals, accuracies = train_pipeline(\n",
    "    '../dataset/train', '../dataset/test', k_values, save_models=True\n",
    ")\n",
    "print(f\"\\nBest accuracy: {max(accuracies):.2f}% at k={k_values[np.argmax(accuracies)]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Accuracy vs k Graph"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(k_values, accuracies, marker='o', linestyle='-', linewidth=2, markersize=8, color='b')\n",
    "plt.xlabel('Number of Principal Components (k)', fontsize=14)\n",
    "plt.ylabel('Accuracy (%)', fontsize=14)\n",
    "plt.title('Accuracy vs Number of Eigenfaces (k)', fontsize=16)\n",
    "plt.grid(True, linestyle='--', alpha=0.7)\n",
    "plt.xticks(k_values)\n",
    "for k, acc in zip(k_values, accuracies):\n",
    "    plt.annotate(f'{acc:.1f}%', (k, acc), textcoords=\"offset points\",\n",
    "                 xytext=(0, 10), ha='center', fontsize=10)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Eigenfaces Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "eigenfaces = best_pca.get_eigenfaces(64, 64)\n",
    "n = len(eigenfaces)\n",
    "cols = 5\n",
    "rows = int(np.ceil(n / cols))\n",
    "fig, axes = plt.subplots(rows, cols, figsize=(cols * 2.5, rows * 2.5))\n",
    "axes = axes.flatten()\n",
    "for i in range(n):\n",
    "    axes[i].imshow(eigenfaces[i], cmap='gray')\n",
    "    axes[i].set_title(f'Eigenface {i+1}', fontsize=9)\n",
    "    axes[i].axis('off')\n",
    "for i in range(n, len(axes)):\n",
    "    axes[i].axis('off')\n",
    "plt.suptitle('Eigenfaces (Principal Components)', fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Mean Face"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mean_face_img = best_pca.mean_face.reshape(64, 64)\n",
    "plt.figure(figsize=(4, 4))\n",
    "plt.imshow(mean_face_img, cmap='gray')\n",
    "plt.title('Mean Face')\n",
    "plt.axis('off')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Explained Variance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cumsum = np.cumsum(best_pca.explained_variance_ratio)\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.bar(range(1, len(best_pca.explained_variance_ratio) + 1),\n",
    "        best_pca.explained_variance_ratio * 100, alpha=0.6, label='Individual')\n",
    "plt.plot(range(1, len(cumsum) + 1), cumsum * 100, 'r-o', label='Cumulative')\n",
    "plt.xlabel('Principal Component')\n",
    "plt.ylabel('Variance Explained (%)')\n",
    "plt.title('Explained Variance by Principal Components')\n",
    "plt.legend()\n",
    "plt.grid(True, linestyle='--', alpha=0.3)\n",
    "plt.show()\n",
    "print(f\"Total variance explained: {cumsum[-1]*100:.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Test on Unknown Faces"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = test_folder('../dataset/test', best_pca, best_ann, label_map, save_dir='../outputs/predictions')\n",
    "for fname, (label, conf) in list(results.items())[:10]:\n",
    "    print(f\"{fname}: {label} ({conf:.2%})\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Imposter Detection"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if os.path.exists('../dataset/imposters'):\n",
    "    imp_results = test_imposters('../dataset/imposters', best_pca, best_ann)\n",
    "    for fname, (label, conf) in imp_results.items():\n",
    "        print(f\"{fname}: {label} ({conf:.2%})\")\n",
    "else:\n",
    "    print(\"No imposter directory found. Create 'dataset/imposters/' with unknown faces to test.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary\n",
    "\n",
    "| k   | Accuracy |\n",
    "|-----|----------|\n" + "".join([f"| {k:3d} | {acc:.2f}%    |\n" for k, acc in zip([5,10,20,30,40], [0]*5)]) + "\n",
    "The optimal k value provides the best balance between dimensionality reduction and recognition accuracy."
   ]
  }
 ],
